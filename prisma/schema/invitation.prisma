model Invitation {
    id              BigInt @id @default(autoincrement())
    email           String
    token           String @default(uuid())
    
    invitedById     BigInt
    invite          UserToProject @relation(fields: [invitedById], references: [id])
    
    projectId       BigInt
    project         Project   @relation(fields: [projectId], references: [id])

    acceptedAt      DateTime?
    expiresAt       DateTime
    createdAt       DateTime  @default(now())

    status          InvitationStatus  @default(PENDING)
    
    @@index([projectId])
    @@index([invitedById])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
  DECLINED
}