model UserToProject {
  id        BigInt  @id @default(autoincrement())
  roleId    Int
  projectId BigInt
  userId    BigInt
  blocked   Boolean

  user       User       @relation(fields: [userId], references: [id])
  userRole   Role   @relation(fields: [roleId], references: [id])
  project    Project    @relation(fields: [projectId], references: [id])
}
