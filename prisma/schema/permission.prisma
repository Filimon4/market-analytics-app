// TODO: Добавить сюда системный тип и иконку и поправить составление панели
model Permission {
  id                Int @id @default(autoincrement())
  name              String  
  code              String  @unique
  description       String?

  parentId          Int?          
  parent            Permission?   @relation("PermissionHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children          Permission[]  @relation("PermissionHierarchy")

  rolePermission    RolePermission[]
}
