// TODO: Поправить составление панели
model Permission {
  id                Int @id @default(autoincrement())
  name              String  
  code              String  @unique
  description       String?
  systemType        String?
  
  iconUrl           String?
  navigationUrl     String?
  panelOrder        String?

  parentId          Int?          
  parent            Permission?   @relation("PermissionHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children          Permission[]  @relation("PermissionHierarchy")

  rolePermission    RolePermission[]
}
