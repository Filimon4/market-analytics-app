model MetricChannel {
  id        BigInt     @id @default(autoincrement())
  name      String
  formula   String     @default("")
  code      String
  deleted   Boolean     @default(false)

  channelId BigInt
  channel   Channel     @relation(fields: [channelId], references: [id])

  metricToUfChannels MetricToUfChannel[]

  channelPerformanceMetricResults ChannelPerformanceMetricResult[]
}